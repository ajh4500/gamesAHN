<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="gamesbyahnprog/css/header.css">
    <link rel="stylesheet" href="gamesbyahnprog/css/auth.css">
    <link rel="stylesheet" href="gamesbyahnprog/css/styles.css">
</head>
<body>
    <header>
        <div class="logo" aria-label="GAME AHN">
            <span class="logo-top">AHN</span>
            <span class="logo-main" aria-hidden="true">
                <span class="logo-letter letter-g">G</span>
                <span class="logo-letter letter-a">A</span>
                <span class="logo-letter letter-m">M</span>
                <span class="logo-letter letter-e">E</span>
            </span>
        </div>

        <nav>
            <a href="#" data-auth-action="login">Log in</a>
            <a href="#" data-auth-action="signup">Sign Up</a>
        </nav>
    </header>

    <main id="games-menu">
        <div class="game-grid">
            <a href="gamesbyahnprog/games/tictactoe/tictacindex.html" class="game-card">
                <img src="gamesbyahnprog/games/tictactoe/image/robot.png" alt="TTTcover">
                <div class="game-name">Tic-Tac-Toe</div>
            </a>

            <a href="gamesbyahnprog/games/connect4/c4index.html" class="game-card">
                <img src="gamesbyahnprog/games/tictactoe/image/robot.png" alt="C4cover">
                <div class="game-name">Connect-4</div>
            </a>

            <div class="game-card"></div>
            <div class="game-card"></div>
            <div class="game-card"></div>
        </div>
    </main>
    <script src="gamesbyahnprog/js/config.js"></script>
    <script src="gamesbyahnprog/js/auth.js"></script>
</body>
</html>
